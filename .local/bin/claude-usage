#!/bin/bash
# claude-usage — wrapper for phuryn/claude-usage at ~/.local/lib/claude-usage/.
# Spec: 00_SYSTEM/docs/superpowers/specs/2026-04-11-claude-usage-dashboard.md
# AND-525: pass-through to upstream cli.py (stats|today|week|dashboard).
# Default (no arg) is `dashboard` per the original spec.
#
# Multi-profile scan via launcher: routes through a Python launcher that
# monkey-patches scanner.DEFAULT_PROJECTS_DIRS to include cc-build + cc-full.
# This is the only correct way to get the dashboard's `/api/rescan` button
# (which deletes the DB and re-scans DEFAULT_PROJECTS_DIRS only) to cover all
# 3 profiles. Doing the multi-profile scan in this Bash wrapper would be
# undone by the very next rescan-button press.

set -euo pipefail

LAUNCHER="$HOME/anders-dotfiles/.local/lib/claude-usage-launcher.py"

if [ $# -eq 0 ]; then
  exec python3 "$LAUNCHER" dashboard
else
  exec python3 "$LAUNCHER" "$@"
fi
