# anders-dotfiles — terminal productivity stack
#
# Install / refresh:
#     brew bundle --file ~/anders-dotfiles/Brewfile
# install.sh runs this automatically (guarded by `command -v brew`).
#
# Pairs with zsh/terminal-stack.zsh, which inits each of these in interactive shells.

brew "starship"                      # prompt (config: config/starship.toml)
brew "atuin"                         # searchable shell history (config: config/atuin/config.toml)
brew "eza"                           # modern ls (ls/ll/la/lt/lT aliases)
brew "yazi"                          # terminal file manager (`yy`)
brew "zoxide"                        # smarter cd (`z`)
brew "bat"                           # cat with syntax highlighting
brew "fzf"                           # fuzzy finder (Ctrl-T / Alt-C / Ctrl-R via atuin)
brew "fd"                            # fast find
brew "ripgrep"                       # fast grep (rg)
brew "zsh-autosuggestions"           # history ghost-text
brew "zsh-fast-syntax-highlighting"  # command syntax highlighting
