{
  "env": {
    "ANDERS_CONFIG": "/Users/sterngold/Code/my-projects/00_SYSTEM/anders-config"
  },
  "cleanupPeriodDays": 90,
  "skillListingBudgetFraction": 0.005,
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(cat *)",
      "Bash(open *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(mkdir *)",
      "Bash(rm -rf __pycache__)",
      "Bash(rm -rf .build)",
      "Bash(rm -rf node_modules)",
      "Bash(npm *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(gh *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(pwd *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(touch *)",
      "Bash(pytest *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "mcp__playwright__*",
      "mcp__supabase__*",
      "mcp__ide__*",
      "NotebookEdit"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf / *)",
      "Bash(rm -r -f /)",
      "Bash(rm -fr /)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git reset --hard*)",
      "Bash(cat */.env*)",
      "Bash(cat */secrets/*)",
      "Bash(cat *credentials*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(*/.env*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(*/.env*)",
      "Write(*/secrets/*)",
      "Edit(*/secrets/*)",
      "Write(//Users/sterngold/Documents/VladFinance/**)",
      "Edit(//Users/sterngold/Documents/VladFinance/**)",
      "Write(//Users/sterngold/Documents/Health/**)",
      "Edit(//Users/sterngold/Documents/Health/**)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /tmp/claude-statusline/mode /tmp/claude-statusline/thinking /tmp/claude-statusline/style"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'rsync.*--delete'; then echo 'BLOCKED: rsync --delete is hard-blocked. Use rsync without --delete, or manage deletions manually.' && exit 1; fi"
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/guard-sensitive-paths.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/guard-agent-model.sh"
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo plan > /tmp/claude-statusline/mode"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /tmp/claude-statusline/mode"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/validate-file.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PROMPT=$(echo \"$CLAUDE_USER_PROMPT\" | tr '[:upper:]' '[:lower:]'); case \"$PROMPT\" in */effort\\ ultra*|*ultrathink*) echo ultra > /tmp/claude-statusline/thinking;; */effort\\ high*) echo high > /tmp/claude-statusline/thinking;; */effort\\ low*|*/effort\\ min*) echo low > /tmp/claude-statusline/thinking;; */effort*) echo auto > /tmp/claude-statusline/thinking;; esac"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": false,
    "claude-md-management@claude-plugins-official": true,
    "playground@claude-plugins-official": false,
    "telegram@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "figma@claude-plugins-official": false,
    "cloudflare@claude-plugins-official": true,
    "linear@claude-plugins-official": true
  },
  "tui": "fullscreen",
  "autoDreamEnabled": false,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": false
}
