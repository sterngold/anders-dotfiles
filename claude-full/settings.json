{
  "cleanupPeriodDays": 90,
  "skillListingBudgetFraction": 0.005,
  "env": {
    "ANDERS_CONFIG": "/Users/sterngold/Code/my-projects/00_SYSTEM/anders-config"
  },
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(cat *)",
      "Bash(open *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(mkdir *)",
      "Bash(rm -rf __pycache__)",
      "Bash(rm -rf .build)",
      "Bash(rm -rf node_modules)",
      "Bash(npm *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(gh *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(pwd *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(touch *)",
      "Bash(pytest *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "mcp__google-gmail__gmail_list_drafts",
      "mcp__google-gmail__gmail_list_labels",
      "mcp__google-gmail__gmail_get_profile",
      "mcp__google-gmail__gmail_read_message",
      "mcp__google-gmail__gmail_read_thread",
      "mcp__google-gmail__gmail_search_messages",
      "mcp__notebooklm__*",
      "mcp__playwright__*",
      "mcp__supabase__*",
      "mcp__ide__*",
      "mcp__plugin_telegram_telegram__*",
      "NotebookEdit",
      "Bash(git push origin main)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf / *)",
      "Bash(rm -r -f /)",
      "Bash(rm -fr /)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git reset --hard*)",
      "Bash(cat */.env*)",
      "Bash(cat */secrets/*)",
      "Bash(cat *credentials*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(*/.env*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(*/.env*)",
      "Write(*/secrets/*)",
      "Edit(*/secrets/*)",
      "Write(//Users/sterngold/Documents/VladFinance/**)",
      "Edit(//Users/sterngold/Documents/VladFinance/**)",
      "Write(//Users/sterngold/Documents/Health/**)",
      "Edit(//Users/sterngold/Documents/Health/**)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /tmp/claude-statusline/mode /tmp/claude-statusline/thinking /tmp/claude-statusline/style"
          },
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/00_SYSTEM/anders-config/tools/session-register.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'rsync.*--delete'; then echo 'BLOCKED: rsync --delete is hard-blocked. Use rsync without --delete, or manage deletions manually.' && exit 1; fi"
          },
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/00_SYSTEM/anders-config/.claude/hooks/guard-bash.sh"
          },
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/guard-deploy.sh"
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/guard-sensitive-paths.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/guard-memory-acl.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/guard-new-hook-audit.sh"
          }
        ]
      },
      {
        "matcher": "Bash|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude-full/egress-gate.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/guard-agent-model.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/skill-memory-reminder.sh"
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo plan > /tmp/claude-statusline/mode"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f /tmp/claude-statusline/mode"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/validate-file.sh"
          },
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/format-python.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/guard-memory-budget.sh"
          }
        ]
      },
      {
        "matcher": "Bash|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude-full/egress-log.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PROMPT=$(echo \"$CLAUDE_USER_PROMPT\" | tr '[:upper:]' '[:lower:]'); case \"$PROMPT\" in */effort\\ ultra*|*ultrathink*) echo ultra > /tmp/claude-statusline/thinking;; */effort\\ high*) echo high > /tmp/claude-statusline/thinking;; */effort\\ low*|*/effort\\ min*) echo low > /tmp/claude-statusline/thinking;; */effort*) echo auto > /tmp/claude-statusline/thinking;; esac"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PROJECTS_ROOT}/.claude/hooks/stop-gate.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "figma@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "cloudflare@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "notion@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "code-modernization@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "autoDreamEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
