{
  "env": {
    "ANDERS_CONFIG": "/Users/sterngold/Code/my-projects/00_SYSTEM/anders-config"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(*)",
      "Write(*)",
      "Edit(*)",
      "NotebookEdit(*)",
      "mcp__playwright__*",
      "mcp__supabase__*",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*"
    ]
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": false,
    "claude-md-management@claude-plugins-official": false,
    "playground@claude-plugins-official": false,
    "telegram@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "firecrawl@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "figma@claude-plugins-official": false
  },
  "voiceEnabled": false,
  "autoDreamEnabled": false,
  "statusLine": { "type": "command", "command": "bash ~/.claude/statusline.sh" },
  "model": "claude-opus-4-7",
  "tui": "fullscreen",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SID=$(jq -r '.session_id // empty' 2>/dev/null); if [ -n \"$SID\" ]; then mkdir -p ~/.claude-partner/transcripts && find ~/.claude-partner/projects -name \"$SID.jsonl\" -exec cp {} ~/.claude-partner/transcripts/$(date +%Y-%m-%d_%H%M)_$SID.jsonl \\; ; fi 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
